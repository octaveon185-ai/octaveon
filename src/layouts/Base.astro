---
import '../styles/tokens.css';
import '../styles/global.css';
import { content, otherLang, homeHref, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = content[lang];
const alt = otherLang(lang);
const canonical = new URL(homeHref(lang), Astro.site).toString();
const altUrl = new URL(homeHref(alt), Astro.site).toString();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t.meta.title}</title>
    <meta name="description" content={t.meta.description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={lang} href={canonical} />
    <link rel="alternate" hreflang={alt} href={altUrl} />
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site).toString()} />

    <link rel="icon" type="image/svg+xml" href="/brand/octave-on-symbol-copper.svg" />
    <meta name="theme-color" content="#030824" />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Octave On" />
    <meta property="og:locale" content={lang === 'it' ? 'it_IT' : 'en_GB'} />
    <meta property="og:title" content={t.meta.title} />
    <meta property="og:description" content={t.meta.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/brand/octave-on-logo.png', Astro.site).toString()} />
    <meta property="og:image:alt" content={t.meta.ogAlt} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Editorial display + clean interface type -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Manrope:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />

    <script>
      import Lenis from 'lenis';

      if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const lenis = new Lenis({ duration: 1.1, smoothWheel: true });

        const raf = (time: number) => {
          lenis.raf(time);
          requestAnimationFrame(raf);
        };
        requestAnimationFrame(raf);

        // Smooth in-page anchor navigation (accounts for the fixed nav).
        document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
          a.addEventListener('click', (e) => {
            const id = a.getAttribute('href');
            if (!id || id === '#') return;
            const target = document.querySelector(id);
            if (!target) return;
            e.preventDefault();
            lenis.scrollTo(target as HTMLElement, { offset: -70 });
          });
        });

        // Expose for other scripts (e.g. the invite success scroll).
        (window as unknown as { lenis: Lenis }).lenis = lenis;
      }
    </script>
  </body>
</html>
