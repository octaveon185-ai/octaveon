---
import { content, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = content[lang].event;
const mapsHref =
  'https://www.google.com/maps/search/?api=1&query=38.570417,-0.077250';
---

<section id="evento" class="oo-event">
  <img class="oo-event__bg" src="/images/altea-event.webp" alt="" width="1920" height="1281" loading="lazy" decoding="async" aria-hidden="true" />
  <div class="oo-event__veil" aria-hidden="true"></div>

  <div class="oo-event__stars" aria-hidden="true">
    <span style="top:16%;left:18%"></span>
    <span style="top:24%;left:72%;animation-delay:.8s"></span>
    <span style="top:62%;left:34%;animation-delay:1.6s"></span>
    <span style="top:40%;left:86%;animation-delay:.4s"></span>
  </div>

  <div class="oo-container oo-reveal oo-event__inner">
    <p class="oo-eyebrow">{t.eyebrow}</p>
    <h2 class="oo-display oo-event__title">{t.title}</h2>

    <dl class="oo-event__facts">
      {t.facts.map((f) => (
        <div class="oo-event__fact">
          <dt>{f.label}</dt>
          <dd>{f.value}</dd>
        </div>
      ))}
    </dl>

    <a class="oo-event__coords" href={mapsHref} target="_blank" rel="noopener">{t.coords}</a>
    <p class="oo-event__note">{t.note}</p>
    <a class="oo-btn oo-btn--primary oo-event__cta" href="#invito">{t.cta}</a>
  </div>
</section>

<style>
  .oo-event {
    position: relative;
    padding: clamp(80px, 12vh, 160px) var(--oo-gutter);
    background: var(--oo-night-800);
    overflow: hidden;
    text-align: center;
  }
  .oo-event__bg {
    position: absolute;
    inset: -8% 0;
    width: 100%;
    height: 116%;
    object-fit: cover;
    object-position: center 35%;
    z-index: 0;
  }
  /* parallax: the photo drifts slower than the content as the section passes */
  @supports (animation-timeline: view()) {
    .oo-event__bg {
      animation: eventBgPar linear both;
      animation-timeline: view();
      animation-range: cover 0% cover 100%;
    }
  }
  /* blue-hour veil so the warm sunset shot reads nocturnal and text stays legible */
  .oo-event__veil {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      linear-gradient(
        180deg,
        var(--oo-night-800) 0%,
        transparent 14%,
        transparent 86%,
        var(--oo-night-700) 100%
      ),
      radial-gradient(120% 90% at 50% 120%, rgba(199, 138, 58, 0.22), transparent 55%),
      linear-gradient(180deg, rgba(2, 19, 32, 0.96) 0%, rgba(2, 19, 32, 0.86) 45%, rgba(4, 27, 42, 0.96) 100%);
  }
  @keyframes eventBgPar {
    from { transform: translateY(-5%); }
    to { transform: translateY(5%); }
  }
  .oo-event__stars span {
    position: absolute;
    width: 2px;
    height: 2px;
    border-radius: 50%;
    background: var(--oo-gold-light);
    animation: twinkle 5s ease-in-out infinite;
  }
  .oo-event__inner {
    position: relative;
    z-index: 1;
    max-width: 760px;
    margin: 0 auto;
  }
  .oo-event__title {
    font-size: var(--oo-fs-h2);
    color: var(--oo-cream-100);
    margin: 18px 0 clamp(40px, 6vh, 64px);
  }
  .oo-event__facts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    border-block: 1px solid rgba(224, 174, 99, 0.18);
    padding: clamp(28px, 4vh, 40px) 0;
  }
  .oo-event__fact dt {
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--oo-gold-light);
    margin-bottom: 10px;
  }
  .oo-event__fact dd {
    font-family: var(--oo-font-display);
    font-size: clamp(20px, 2.4vw, 30px);
    color: var(--oo-cream-100);
  }
  .oo-event__coords {
    display: inline-block;
    margin-top: 28px;
    font-size: 12px;
    letter-spacing: 0.16em;
    color: var(--oo-slate);
    border-bottom: 1px solid rgba(143, 168, 179, 0.35);
    padding-bottom: 4px;
    transition: color 0.25s, border-color 0.25s;
  }
  .oo-event__coords:hover {
    color: var(--oo-gold-light);
    border-color: var(--oo-gold-light);
  }
  .oo-event__note {
    margin: 26px auto 0;
    max-width: 520px;
    color: var(--oo-slate);
  }
  .oo-event__cta {
    margin-top: 38px;
  }

  @media (max-width: 600px) {
    .oo-event__facts {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }
</style>
