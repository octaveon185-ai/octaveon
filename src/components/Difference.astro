---
import { content, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = content[lang].difference;
---

<section class="oo-diff">
  <div class="oo-container oo-reveal oo-diff__inner">
    <blockquote class="oo-diff__quote">
      <p class="oo-display">{t.quote}</p>
      <footer>— {t.author}</footer>
    </blockquote>
  </div>
</section>

<style>
  .oo-diff {
    position: relative;
    min-height: min(76vh, 760px);
    padding: clamp(120px, 20vh, 240px) var(--oo-gutter);
    background: var(--oo-grad-night);
    overflow: hidden;
    display: grid;
    place-items: center;
    text-align: center;
  }
  .oo-diff::before {
    content: '“';
    position: absolute;
    top: 50%;
    left: 50%;
    translate: -50% -55%;
    font-family: var(--oo-font-display);
    font-size: clamp(280px, 38vw, 580px);
    line-height: 1;
    color: rgba(224, 174, 99, 0.035);
    pointer-events: none;
  }
  .oo-diff__inner {
    position: relative;
    z-index: 1;
    max-width: 1080px;
  }
  .oo-diff__quote {
    margin: 0 auto;
  }
  .oo-diff__quote p {
    margin: 0;
    font-size: clamp(54px, 8.5vw, 118px);
    line-height: 1.02;
    font-weight: 400;
    color: var(--oo-cream-100);
    text-wrap: balance;
  }
  .oo-diff__quote footer {
    margin-top: clamp(34px, 5vh, 54px);
    color: var(--oo-gold-light);
    font-size: clamp(12px, 1.2vw, 15px);
    font-style: normal;
    letter-spacing: 0.28em;
    text-transform: uppercase;
  }

  @media (max-width: 600px) {
    .oo-diff {
      min-height: 70vh;
      padding-block: 120px;
    }
    .oo-diff__quote p {
      font-size: clamp(48px, 14vw, 62px);
      line-height: 1.06;
    }
  }
</style>
