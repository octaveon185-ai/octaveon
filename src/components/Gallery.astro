---
import { content, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = content[lang].gallery;
---

<section id="gallery" class="oo-gallery">
  <div class="oo-container">
    <div class="oo-reveal oo-gallery__head">
      <p class="oo-eyebrow">{t.eyebrow}</p>
      <h2 class="oo-display oo-gallery__title">{t.title}</h2>
    </div>

    <div class="oo-reveal oo-reveal--soft oo-gallery__grid">
      {t.tiles.map((caption, i) => (
        <figure class="oo-gallery__tile">
          <img
            src={`/images/altea-${i + 1}.webp`}
            alt={caption}
            width="1100"
            height="730"
            loading="lazy"
            decoding="async"
          />
          <figcaption>{caption}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .oo-gallery {
    position: relative;
    padding: clamp(70px, 10vh, 130px) var(--oo-gutter);
    background: linear-gradient(180deg, var(--oo-night-700) 0%, var(--oo-night-800) 100%);
  }
  .oo-gallery__head {
    text-align: center;
    margin-bottom: clamp(40px, 6vh, 64px);
  }
  .oo-gallery__title {
    font-size: var(--oo-fs-h2);
    color: var(--oo-cream-100);
    margin-top: 16px;
  }

  .oo-gallery__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: clamp(150px, 18vw, 210px);
    gap: 14px;
  }
  .oo-gallery__tile:nth-child(1) { grid-column: span 2; grid-row: span 2; }
  .oo-gallery__tile:nth-child(4) { grid-column: span 2; }
  .oo-gallery__tile:nth-child(6) { grid-column: span 2; }

  .oo-gallery__tile {
    position: relative;
    border-radius: var(--oo-radius);
    overflow: hidden;
    border: 1px solid rgba(224, 174, 99, 0.14);
    margin: 0;
  }
  .oo-gallery__tile img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--oo-ease);
  }
  /* night-mood overlay: keeps the bright photos within the palette + caption legibility */
  .oo-gallery__tile::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(2, 19, 32, 0.18) 0%, transparent 30%, rgba(1, 13, 22, 0.84) 100%),
      rgba(2, 19, 32, 0.14);
    transition: background 0.4s var(--oo-ease);
  }
  .oo-gallery__tile:hover img { transform: scale(1.06); }
  .oo-gallery__tile:hover::after {
    background:
      linear-gradient(180deg, rgba(2, 19, 32, 0.06) 0%, transparent 35%, rgba(1, 13, 22, 0.74) 100%),
      rgba(2, 19, 32, 0.03);
  }

  .oo-gallery__tile figcaption {
    position: absolute;
    left: 18px;
    bottom: 16px;
    z-index: 1;
    font-family: var(--oo-font-display);
    font-style: italic;
    font-size: clamp(15px, 1.4vw, 21px);
    color: var(--oo-cream-100);
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.6);
  }

  @media (max-width: 760px) {
    .oo-gallery__grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .oo-gallery__tile:nth-child(1) { grid-column: span 2; grid-row: span 1; }
    .oo-gallery__tile:nth-child(4),
    .oo-gallery__tile:nth-child(6) { grid-column: span 2; }
  }
</style>
