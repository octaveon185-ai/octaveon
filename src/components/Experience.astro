---
import { content, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = content[lang].experience;
---

<section id="esperienza" class="oo-exp">
  <div class="oo-container">
    <div class="oo-reveal oo-exp__head">
      <p class="oo-eyebrow oo-exp__eyebrow">{t.eyebrow}</p>
      <h2 class="oo-display oo-exp__title">{t.title}</h2>
      <p class="oo-exp__intro">{t.intro}</p>
    </div>

    <ol class="oo-exp__list">
      {t.rituals.map((r, i) => (
        <li class="oo-reveal oo-exp__row" data-flip={i % 2 === 1 ? 'true' : 'false'}>
          <div class="oo-exp__emblem" aria-hidden="true">
            <span class="oo-exp__ring oo-exp__ring--outer"></span>
            <span class="oo-exp__ring oo-exp__ring--inner"></span>
            <span class="oo-exp__num">{r.num}</span>
          </div>
          <div class="oo-exp__body">
            <p class="oo-exp__essence">{r.essence}</p>
            <h3 class="oo-display oo-exp__name">{r.name}</h3>
            <p class="oo-exp__sub">{r.sub}</p>
            <span class="oo-exp__rule" aria-hidden="true"></span>
            <p class="oo-exp__desc">{r.desc}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .oo-exp {
    position: relative;
    padding: clamp(40px, 6vh, 80px) var(--oo-gutter) clamp(80px, 11vh, 150px);
    background: var(--oo-grad-goldenhour);
    color: var(--oo-text-on-dark);
    overflow: hidden;
  }
  .oo-exp::before { content: none; }
  .oo-exp .oo-container { position: relative; z-index: 1; }
  .oo-exp__head {
    text-align: center;
    max-width: 640px;
    margin: 0 auto clamp(56px, 9vh, 104px);
  }
  .oo-exp__eyebrow { color: var(--oo-gold-light); margin-bottom: 20px; }
  .oo-exp__title { font-size: var(--oo-fs-h2); color: var(--oo-cream-100); }
  .oo-exp__intro { margin-top: 20px; color: rgba(234, 231, 227, 0.68); }

  .oo-exp__list {
    list-style: none;
    max-width: 940px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: clamp(40px, 6vh, 74px);
  }
  .oo-exp__row {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) 1.1fr;
    gap: clamp(28px, 6vw, 86px);
    align-items: center;
    padding-bottom: clamp(40px, 6vh, 74px);
    border-bottom: 1px solid rgba(211, 154, 97, 0.16);
  }
  .oo-exp__row:last-child { border-bottom: none; padding-bottom: 0; }
  .oo-exp__row[data-flip='true'] .oo-exp__emblem { order: 2; }
  .oo-exp__row[data-flip='true'] .oo-exp__body { text-align: right; }
  .oo-exp__row[data-flip='true'] .oo-exp__rule { margin-left: auto; }

  /* refined gold emblem */
  .oo-exp__emblem {
    position: relative;
    width: clamp(150px, 22vw, 240px);
    aspect-ratio: 1;
    margin: 0 auto;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(27, 94, 217, 0.22), rgba(3, 8, 36, 0) 68%);
  }
  .oo-exp__emblem::before,
  .oo-exp__emblem::after {
    content: none;
  }
  .oo-exp__ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(211, 154, 97, 0.5);
  }
  .oo-exp__ring--outer {
    inset: 0;
    border-color: rgba(230, 190, 102, 0.36);
    transition: transform 0.8s var(--oo-ease);
  }
  .oo-exp__ring--inner {
    inset: 22%;
    border-color: rgba(230, 190, 102, 0.18);
  }
  .oo-exp__row:hover .oo-exp__ring--outer { transform: scale(1.07); }
  .oo-exp__num {
    position: relative;
    z-index: 1;
    font-family: var(--oo-font-display);
    font-size: clamp(48px, 8vw, 88px);
    line-height: 1;
    color: transparent;
    background: linear-gradient(180deg, var(--oo-gold-glow), var(--oo-gold));
    -webkit-background-clip: text;
    background-clip: text;
  }

  .oo-exp__essence {
    font-size: 11px;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--oo-gold-light);
    margin-bottom: 14px;
  }
  .oo-exp__name { font-size: var(--oo-fs-h3); color: var(--oo-cream-100); }
  .oo-exp__sub {
    font-size: 12px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(154, 171, 180, 0.7);
    margin: 8px 0 0;
  }
  .oo-exp__rule {
    display: block;
    width: 54px;
    height: 1px;
    margin: 22px 0;
    background: linear-gradient(90deg, rgba(211, 154, 97, 0.75), transparent);
  }
  .oo-exp__desc { color: rgba(234, 231, 227, 0.72); max-width: 42ch; }
  .oo-exp__row[data-flip='true'] .oo-exp__desc { margin-left: auto; }

  @media (max-width: 760px) {
    .oo-exp__row,
    .oo-exp__row[data-flip='true'] .oo-exp__emblem {
      grid-template-columns: 1fr;
      order: 0;
      text-align: center;
    }
    .oo-exp__row[data-flip='true'] .oo-exp__body { text-align: center; }
    .oo-exp__body { text-align: center; }
    .oo-exp__rule,
    .oo-exp__row[data-flip='true'] .oo-exp__rule { margin: 20px auto; }
    .oo-exp__desc { margin: 0 auto; }
    .oo-exp__emblem { width: clamp(130px, 40vw, 190px); }
  }
</style>
