---
import { content, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = content[lang].experience;
---

<section id="esperienza" class="oo-exp">
  <div class="oo-container">
    <div class="oo-reveal oo-exp__head">
      <p class="oo-eyebrow oo-exp__eyebrow">{t.eyebrow}</p>
      <h2 class="oo-display oo-exp__title">{t.title}</h2>
      <p class="oo-exp__intro">{t.intro}</p>
    </div>

    <ol class="oo-exp__list">
      {t.rituals.map((r, i) => (
        <li class="oo-reveal oo-exp__row" data-flip={i % 2 === 1 ? 'true' : 'false'}>
          <div class="oo-exp__media" aria-hidden="true">
            <span class="oo-exp__num">{r.num}</span>
            <span class="oo-exp__ring"></span>
          </div>
          <div class="oo-exp__body">
            <p class="oo-exp__essence">{r.essence}</p>
            <h3 class="oo-display oo-exp__name">{r.name}</h3>
            <p class="oo-exp__sub">{r.sub}</p>
            <p class="oo-exp__desc">{r.desc}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .oo-exp {
    position: relative;
    padding: clamp(40px, 6vh, 80px) var(--oo-gutter) clamp(80px, 11vh, 150px);
    background: var(--oo-grad-goldenhour);
    color: var(--oo-text-on-light);
    overflow: hidden;
  }
  .oo-exp__head {
    text-align: center;
    max-width: 640px;
    margin: 0 auto clamp(52px, 8vh, 92px);
  }
  .oo-exp__eyebrow {
    color: var(--oo-gold-dark);
    margin-bottom: 20px;
  }
  .oo-exp__title {
    font-size: var(--oo-fs-h2);
  }
  .oo-exp__intro {
    margin-top: 20px;
    color: rgba(42, 27, 16, 0.72);
  }

  .oo-exp__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: clamp(48px, 7vh, 96px);
  }
  .oo-exp__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(28px, 5vw, 72px);
    align-items: center;
  }
  .oo-exp__row[data-flip='true'] .oo-exp__media {
    order: 2;
  }

  .oo-exp__media {
    position: relative;
    aspect-ratio: 16 / 11;
    border-radius: var(--oo-radius);
    background:
      radial-gradient(120% 120% at 30% 20%, rgba(255, 255, 255, 0.45), transparent 55%),
      linear-gradient(140deg, rgba(199, 138, 58, 0.28), rgba(122, 74, 48, 0.34));
    border: 1px solid rgba(154, 103, 44, 0.28);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .oo-exp__num {
    font-family: var(--oo-font-display);
    font-size: clamp(64px, 11vw, 130px);
    color: rgba(42, 27, 16, 0.18);
    line-height: 1;
  }
  .oo-exp__ring {
    position: absolute;
    width: 38%;
    aspect-ratio: 1;
    border: 1.5px solid rgba(242, 233, 218, 0.7);
    border-radius: 50%;
    animation: drift 10s ease-in-out infinite;
  }

  .oo-exp__essence {
    font-size: 11.5px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--oo-gold-dark);
    margin-bottom: 14px;
  }
  .oo-exp__name {
    font-size: var(--oo-fs-h3);
  }
  .oo-exp__sub {
    font-size: 12px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(42, 27, 16, 0.5);
    margin: 6px 0 18px;
  }
  .oo-exp__desc {
    color: rgba(42, 27, 16, 0.78);
    max-width: 38ch;
  }

  @media (max-width: 760px) {
    .oo-exp__row,
    .oo-exp__row[data-flip='true'] .oo-exp__media {
      grid-template-columns: 1fr;
      order: 0;
    }
  }
</style>
