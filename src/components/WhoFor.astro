---
import { content, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = content[lang].whoFor;
---

<section class="oo-who">
  <div class="oo-container oo-reveal oo-who__inner">
    <p class="oo-eyebrow oo-who__eyebrow">{t.eyebrow}</p>
    <h2 class="oo-display oo-who__title">{t.title}</h2>
    <ul class="oo-who__points">
      {t.points.map((p) => <li>{p}</li>)}
    </ul>
    <div class="oo-who__tags">
      {t.tags.map((tag) => <span>{tag}</span>)}
    </div>
  </div>
</section>

<style>
  .oo-who {
    position: relative;
    padding: clamp(80px, 12vh, 150px) var(--oo-gutter);
    text-align: center;
    background: var(--oo-grad-dusk);
    color: var(--oo-text-on-dark);
    overflow: hidden;
  }
  .oo-who::before {
    content: none;
  }
  .oo-who__inner {
    position: relative;
    z-index: 1;
    max-width: 780px;
  }
  .oo-who__eyebrow {
    color: var(--oo-gold-light);
    margin-bottom: 24px;
  }
  .oo-who__title {
    font-size: var(--oo-fs-h2);
    color: var(--oo-cream-100);
  }
  .oo-who__points {
    list-style: none;
    margin: 36px auto 0;
    max-width: 560px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .oo-who__points li {
    font-size: clamp(16px, 1.5vw, 20px);
    color: rgba(234, 231, 227, 0.78);
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(211, 154, 97, 0.16);
  }
  .oo-who__points li:last-child {
    border-bottom: none;
  }
  .oo-who__tags {
    margin-top: 40px;
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .oo-who__tags span {
    font-size: 11.5px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--oo-gold-light);
    border: 1px solid rgba(211, 154, 97, 0.34);
    border-radius: var(--oo-radius-pill);
    padding: 10px 22px;
  }
</style>
