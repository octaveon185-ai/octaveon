---
import { content, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = content[lang].whoFor;
---

<section class="oo-who">
  <div class="oo-container oo-reveal oo-who__inner">
    <p class="oo-display oo-who__body">{t.body}</p>
    <div class="oo-who__divider" aria-hidden="true"></div>
    <p class="oo-who__closing">{t.closing}</p>
  </div>
</section>

<style>
  .oo-who {
    position: relative;
    padding: clamp(110px, 18vh, 210px) var(--oo-gutter);
    text-align: center;
    background: var(--oo-grad-dusk);
    color: var(--oo-text-on-dark);
    overflow: hidden;
  }
  .oo-who::before {
    content: none;
  }
  .oo-who__inner {
    position: relative;
    z-index: 1;
    max-width: 980px;
  }
  .oo-who__body {
    margin: 0 auto;
    max-width: 900px;
    color: var(--oo-cream-100);
    font-size: clamp(30px, 4.15vw, 58px);
    line-height: 1.14;
    text-wrap: balance;
  }
  .oo-who__divider {
    width: 56px;
    height: 1px;
    margin: clamp(42px, 7vh, 72px) auto;
    background: linear-gradient(90deg, transparent, var(--oo-gold-light), transparent);
  }
  .oo-who__closing {
    max-width: 660px;
    margin: 0 auto;
    font-size: clamp(14px, 1.5vw, 18px);
    line-height: 1.7;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--oo-gold-light);
    text-wrap: balance;
  }

  @media (max-width: 600px) {
    .oo-who {
      padding-block: 100px;
    }
    .oo-who__body {
      font-size: clamp(29px, 8.2vw, 36px);
      line-height: 1.18;
    }
    .oo-who__closing {
      font-size: 12px;
      letter-spacing: 0.1em;
    }
  }
</style>
