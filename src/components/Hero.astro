---
import { content, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = content[lang].hero;
const dervishFrames = Array.from(
  { length: 10 },
  (_, index) => `/images/hero-dervish-frame-${String(index + 1).padStart(2, '0')}.webp`,
);
const torusCircles = Array.from({ length: 12 }, (_, i) => {
  const angle = (i / 12) * Math.PI * 2;
  return {
    cx: 300 + Math.cos(angle) * 72,
    cy: 300 + Math.sin(angle) * 72,
  };
});
---

<header id="hero" class="oo-hero">
  <!-- LAYER 1 · sky atmosphere (back) — parallax slow -->
  <div class="oo-hero__atmos" aria-hidden="true">
    <div class="oo-hero__glow"></div>
    <div class="oo-hero__cosmos">
      <svg viewBox="0 0 600 600" fill="none">
        <circle cx="300" cy="300" r="218"></circle>
        <circle cx="300" cy="300" r="146"></circle>
        {torusCircles.map(({ cx, cy }) => <circle cx={cx} cy={cy} r="166"></circle>)}
      </svg>
    </div>
    <div class="oo-hero__stars">
      <span style="top:18%;left:14%;animation-delay:0s"></span>
      <span style="top:28%;left:78%;animation-delay:.8s"></span>
      <span style="top:40%;left:42%;animation-delay:1.6s"></span>
      <span style="top:22%;left:58%;animation-delay:2.2s"></span>
      <span style="top:34%;left:88%;animation-delay:.4s"></span>
      <span style="top:14%;left:34%;animation-delay:1.2s"></span>
    </div>
  </div>

  <!-- LAYER 2 · whirling dervish (mid, behind content) -->
  <div class="oo-hero__layer oo-hero__dancer" data-dervish aria-hidden="true">
    {dervishFrames.map((src, index) => (
      <img
        class={`oo-hero__dancer-frame${index === 0 ? ' is-active' : ''}`}
        src={src}
        alt=""
        width="768"
        height="1536"
        loading="eager"
        decoding="async"
        fetchpriority={index === 0 ? 'high' : 'low'}
      />
    ))}
  </div>

  <!-- LAYER 3 · content (mid-front) -->
  <div class="oo-hero__inner">
    <div class="oo-hero__brand">
      <img src="/brand/octave-on-logo.png" alt="Octave On" width="1064" height="671" />
    </div>

    <p class="oo-eyebrow oo-hero__eyebrow">{t.eyebrow}</p>
    <h1 class="oo-display oo-hero__title">{t.title}</h1>
    <p class="oo-hero__subtitle">{t.subtitle}</p>

    <div class="oo-hero__cta">
      <a class="oo-btn oo-btn--primary" href="#invito">{t.ctaPrimary}</a>
      <a class="oo-btn oo-btn--ghost" href="#esperienza">{t.ctaSecondary}</a>
    </div>
  </div>

  <!-- LAYER 4 · gold embers floating up (front) -->
  <div class="oo-hero__embers" aria-hidden="true">
    {Array.from({ length: 9 }).map((_, i) => (
      <span style={`left:${8 + i * 10}%;animation-delay:${(i * 0.9).toFixed(1)}s;animation-duration:${(7 + (i % 4)).toFixed(0)}s`}></span>
    ))}
  </div>

  <!-- LAYER 5 · sacred geometry (foreground) -->
  <div class="oo-hero__geometry oo-hero__geometry--left" aria-hidden="true">
    <svg viewBox="0 0 260 260" fill="none">
      <circle cx="130" cy="130" r="112"></circle>
      <circle cx="130" cy="130" r="42"></circle>
      <circle cx="172" cy="130" r="42"></circle>
      <circle cx="151" cy="166.4" r="42"></circle>
      <circle cx="109" cy="166.4" r="42"></circle>
      <circle cx="88" cy="130" r="42"></circle>
      <circle cx="109" cy="93.6" r="42"></circle>
      <circle cx="151" cy="93.6" r="42"></circle>
      <path d="M130 18L227 74V186L130 242L33 186V74L130 18Z"></path>
    </svg>
  </div>
  <div class="oo-hero__geometry oo-hero__geometry--right" aria-hidden="true">
    <svg viewBox="0 0 260 260" fill="none">
      <circle cx="130" cy="130" r="112"></circle>
      <path d="M130 18L227 74L227 186L130 242L33 186L33 74L130 18ZM130 18L130 242M33 74L227 186M227 74L33 186M33 74L227 74L227 186L33 186Z"></path>
      <path d="M130 74L178 102L178 158L130 186L82 158L82 102L130 74Z"></path>
      {[{x:130,y:18},{x:227,y:74},{x:227,y:186},{x:130,y:242},{x:33,y:186},{x:33,y:74},{x:130,y:74},{x:178,y:102},{x:178,y:158},{x:130,y:186},{x:82,y:158},{x:82,y:102},{x:130,y:130}].map(({x,y}) => <circle cx={x} cy={y} r="6"></circle>)}
    </svg>
  </div>

  <a class="oo-hero__scroll" href="#manifesto" aria-label={t.scroll}>
    <span class="oo-hero__scroll-label">{t.scroll}</span>
    <span class="oo-hero__scroll-track" aria-hidden="true"><i></i></span>
  </a>
</header>

<style>
  .oo-hero {
    --mx: 0;
    --my: 0;
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 130px var(--oo-gutter) 96px;
    overflow: hidden;
    background:
      linear-gradient(180deg, transparent 62%, var(--oo-night-800) 100%),
      radial-gradient(circle at 50% 86%, rgba(184, 115, 51, 0.2), transparent 34%),
      linear-gradient(158deg, var(--oo-night-600) 0%, var(--oo-night-800) 64%, var(--oo-night-800) 100%);
  }
  .oo-hero::after {
    content: '';
    position: absolute;
    inset: auto 0 -1px;
    z-index: 2;
    height: clamp(100px, 15vh, 150px);
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(2, 19, 32, 0) 0%,
      rgba(2, 19, 32, 0.88) 62%,
      var(--oo-night-800) 100%
    );
  }

  /* ---- LAYER 1 · atmosphere ---- */
  .oo-hero__atmos {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  @supports (animation-timeline: scroll(root)) {
    .oo-hero__atmos {
      animation: parDown linear both;
      animation-timeline: scroll(root);
      animation-range: 0 110vh;
    }
  }
  .oo-hero__glow {
    position: absolute;
    left: 50%;
    bottom: -32%;
    width: 140%;
    height: 80%;
    transform: translateX(-50%);
    background: radial-gradient(
      ellipse at center,
      rgba(211, 154, 97, 0.3) 0%,
      rgba(184, 115, 51, 0.12) 38%,
      transparent 68%
    );
    animation: glowPulse 7s ease-in-out infinite;
  }
  .oo-hero__cosmos {
    position: absolute;
    left: 50%;
    bottom: -34%;
    width: min(76vw, 880px);
    aspect-ratio: 1;
    color: var(--oo-gold-light);
    opacity: 0.1;
    transform: translateX(-50%);
    filter: drop-shadow(0 0 30px rgba(184, 115, 51, 0.22));
  }
  .oo-hero__cosmos svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    stroke-width: 1;
    transform-origin: center;
    animation: ringSpin 110s linear infinite;
  }
  .oo-hero__stars span {
    position: absolute;
    width: 2px;
    height: 2px;
    border-radius: 50%;
    background: var(--oo-gold-light);
    animation: twinkle 5s ease-in-out infinite;
  }

  /* ---- Shared parallax layer behaviour ----
     transform ← scroll parallax · translate ← mouse · rotate ← sway
     (three independent properties compose cleanly) */
  .oo-hero__layer,
  .oo-hero__geometry {
    position: absolute;
    pointer-events: none;
    transition: translate 0.5s var(--oo-ease);
    translate: calc(var(--mx) * var(--depth) * 1px) calc(var(--my) * var(--depth) * 0.6px);
  }

  /* ---- LAYER 2 · whirling dervish ---- */
  .oo-hero__dancer {
    --depth: 16;
    bottom: -2%;
    left: 50%;
    height: min(94svh, 960px);
    aspect-ratio: 1 / 2;
    margin-left: calc(min(94svh, 960px) / -4);
    opacity: 0.58;
    filter: saturate(1) brightness(1.08) drop-shadow(0 0 52px rgba(184, 115, 51, 0.28));
    animation: heroSway 12s ease-in-out infinite;
  }
  .oo-hero__dancer-frame {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0;
    transition: opacity 140ms ease-in-out;
    will-change: opacity;
  }
  .oo-hero__dancer-frame.is-active {
    opacity: 1;
  }

  /* ---- LAYER 3 · content ---- */
  .oo-hero__inner {
    position: relative;
    z-index: 3;
    width: min(100%, 960px);
    min-width: 0;
  }
  @supports (animation-timeline: view()) {
    .oo-hero__inner > * {
      animation: revealSoft both 1s var(--oo-ease);
    }
  }
  .oo-hero__brand {
    position: relative;
    width: clamp(280px, 30vw, 420px);
    margin: 0 auto clamp(14px, 2.5vh, 24px);
    translate: 0 -30px;
    filter:
      drop-shadow(0 0 22px rgba(211, 154, 97, 0.52))
      drop-shadow(0 12px 34px rgba(1, 8, 13, 0.72));
  }
  .oo-hero__brand img {
    width: 100%;
    height: auto;
  }
  .oo-hero__eyebrow { margin-bottom: 24px; }
  .oo-hero__title {
    width: min(100%, 880px);
    max-width: 14ch;
    margin-inline: auto;
    font-size: clamp(48px, 6vw, 82px);
    color: var(--oo-cream-100);
    letter-spacing: -0.01em;
    text-wrap: balance;
    text-shadow: 0 2px 30px rgba(1, 8, 13, 0.8);
  }
  .oo-hero__subtitle {
    margin: 26px auto 0;
    max-width: 560px;
    color: rgba(234, 231, 227, 0.7);
    font-size: clamp(16px, 1.4vw, 20px);
    line-height: 1.6;
  }
  .oo-hero__cta {
    width: min(100%, 620px);
    margin: 40px auto 0;
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ---- LAYER 4 · embers ---- */
  .oo-hero__embers {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
  }
  .oo-hero__embers span {
    position: absolute;
    bottom: -10px;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--oo-gold-light);
    box-shadow: 0 0 8px 1px rgba(224, 174, 99, 0.7);
    opacity: 0;
    animation: emberRise linear infinite;
  }

  /* ---- LAYER 5 · sacred geometry (foreground framing) ---- */
  .oo-hero__geometry {
    bottom: -4%;
    z-index: 2;
    width: clamp(210px, 25vw, 360px);
    color: var(--oo-gold-light);
    opacity: 0.32;
    filter: drop-shadow(0 0 24px rgba(184, 115, 51, 0.34));
  }
  .oo-hero__geometry svg {
    width: 100%;
    height: auto;
    display: block;
    stroke: currentColor;
    stroke-width: 1.15;
    vector-effect: non-scaling-stroke;
  }
  .oo-hero__geometry--left {
    --depth: 34;
    left: -3%;
    transform-origin: bottom left;
    animation: heroSwayGeometry 12s ease-in-out infinite;
  }
  .oo-hero__geometry--right {
    --depth: 28;
    right: -3%;
    transform-origin: bottom right;
    animation: heroSwayGeometry 14s ease-in-out infinite reverse;
  }

  /* scroll parallax: foreground moves up, dancer drifts down (depth) */
  @supports (animation-timeline: scroll(root)) {
    .oo-hero__dancer { --py: 26px; }
    .oo-hero__geometry--left { --py: -46px; }
    .oo-hero__geometry--right { --py: -38px; }
    .oo-hero__dancer,
    .oo-hero__geometry {
      animation-name: heroParallax;
      animation-timing-function: linear;
      animation-fill-mode: both;
      animation-timeline: scroll(root);
      animation-range: 0 100vh;
    }
    /* keep the sway as a second, infinite animation on a wrapper-free element
       by letting parallax own `transform` and sway own `rotate` */
    .oo-hero__dancer { animation-name: heroParallax, heroSway; animation-duration: 1s, 12s; animation-iteration-count: 1, infinite; animation-timeline: scroll(root), auto; animation-range: 0 100vh, normal; }
    .oo-hero__geometry--left { animation-name: heroParallax, heroSwayGeometry; animation-duration: 1s, 12s; animation-iteration-count: 1, infinite; animation-timeline: scroll(root), auto; animation-range: 0 100vh, normal; }
    .oo-hero__geometry--right { animation-name: heroParallax, heroSwayGeometry; animation-duration: 1s, 14s; animation-iteration-count: 1, infinite; animation-direction: normal, reverse; animation-timeline: scroll(root), auto; animation-range: 0 100vh, normal; }
  }

  /* ---- scroll hint ---- */
  .oo-hero__scroll {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    z-index: 5;
  }
  .oo-hero__scroll-label {
    font-size: 10.5px;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: var(--oo-slate);
  }
  .oo-hero__scroll-track {
    position: relative;
    width: 22px;
    height: 34px;
    border: 1px solid rgba(143, 168, 179, 0.5);
    border-radius: 12px;
  }
  .oo-hero__scroll-track i {
    position: absolute;
    top: 7px;
    left: 50%;
    width: 3px;
    height: 3px;
    margin-left: -1.5px;
    border-radius: 50%;
    background: var(--oo-gold-light);
    animation: scrollDot 1.8s ease-in-out infinite;
  }

  @media (max-width: 700px) {
    .oo-hero {
      padding: 122px var(--oo-gutter) 92px;
    }
    .oo-hero__brand {
      width: min(78vw, 300px);
      margin-bottom: 18px;
      translate: 0 -24px;
    }
    .oo-hero__eyebrow { margin-bottom: 18px; }
    .oo-hero__title { max-width: 13ch; font-size: clamp(38px, 12vw, 52px); }
    .oo-hero__subtitle { font-size: 15px; }
    .oo-hero__cta {
      width: min(100%, 320px);
      flex-direction: column;
      align-items: stretch;
    }
    .oo-hero__cta .oo-btn { width: 100%; }
    .oo-hero__dancer {
      bottom: -1%;
      height: min(82svh, 720px);
      margin-left: calc(min(82svh, 720px) / -4);
      opacity: 0.48;
    }
    .oo-hero__geometry { width: 48vw; bottom: -2%; opacity: 0.24; }
    .oo-hero__geometry--left { left: -18%; }
    .oo-hero__geometry--right { right: -18%; }
    .oo-hero__cosmos { width: 150vw; bottom: -20%; opacity: 0.08; }
  }

  @media (max-height: 700px) {
    .oo-hero { padding-top: 94px; padding-bottom: 58px; }
    .oo-hero__brand {
      width: 220px;
      margin-bottom: 6px;
      translate: 0 -22px;
    }
    .oo-hero__eyebrow { margin-bottom: 10px; }
    .oo-hero__title { font-size: clamp(36px, 7.4vh, 48px); }
    .oo-hero__subtitle {
      margin-top: 12px;
      max-width: 520px;
      font-size: 14px;
      line-height: 1.45;
    }
    .oo-hero__cta { margin-top: 18px; }
    .oo-hero__scroll { display: none; }
    .oo-hero__dancer {
      bottom: -4%;
      height: min(96svh, 720px);
      margin-left: calc(min(96svh, 720px) / -4);
    }
  }

  @media (min-width: 520px) and (max-width: 700px) and (max-height: 700px) {
    .oo-hero__cta {
      width: min(100%, 560px);
      flex-direction: row;
    }
    .oo-hero__cta .oo-btn {
      flex: 1;
      min-width: 0;
      padding-inline: 16px;
      font-size: 11.5px;
    }
  }

</style>

<style is:global>
  @keyframes heroParallax { to { transform: translateY(var(--py, 0)); } }
  @keyframes heroSway {
    0%, 100% { rotate: -1.5deg; }
    50% { rotate: 1.5deg; }
  }
  @keyframes heroSwayGeometry {
    0%, 100% { rotate: -1.2deg; scale: 1; }
    50% { rotate: 1.2deg; scale: 1.025; }
  }
  @keyframes emberRise {
    0% { transform: translateY(0) translateX(0); opacity: 0; }
    12% { opacity: 0.9; }
    80% { opacity: 0.7; }
    100% { transform: translateY(-78vh) translateX(18px); opacity: 0; }
  }
</style>

<script>
  // Start the turn only when every frame is decoded, avoiding flashes mid-loop.
  document.querySelectorAll('[data-dervish]').forEach((dancer) => {
    const frames = Array.from(dancer.querySelectorAll('img'));
    const ready = frames.map((frame) => {
      if (frame.complete) return Promise.resolve();
      return new Promise<void>((resolve) => {
        frame.addEventListener('load', () => resolve(), { once: true });
        frame.addEventListener('error', () => resolve(), { once: true });
      });
    });
    Promise.all(ready).then(() => {
      dancer.classList.add('is-ready');
      if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      let current = 0;
      window.setInterval(() => {
        frames[current].classList.remove('is-active');
        current = (current + 1) % frames.length;
        frames[current].classList.add('is-active');
      }, 320);
    });
  });

  // Mouse parallax: feed cursor position into --mx / --my on the hero.
  const hero = document.getElementById('hero');
  if (hero && matchMedia('(pointer:fine)').matches && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let raf = 0;
    hero.addEventListener('pointermove', (e) => {
      const r = hero.getBoundingClientRect();
      const mx = (e.clientX - r.left) / r.width - 0.5;
      const my = (e.clientY - r.top) / r.height - 0.5;
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => {
        hero.style.setProperty('--mx', mx.toFixed(3));
        hero.style.setProperty('--my', my.toFixed(3));
      });
    });
    hero.addEventListener('pointerleave', () => {
      hero.style.setProperty('--mx', '0');
      hero.style.setProperty('--my', '0');
    });
  }
</script>
