---
import { content, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = content[lang].hero;
---

<header id="hero" class="oo-hero">
  <div class="oo-hero__silk" aria-hidden="true">
    <span class="oo-hero__wave oo-hero__wave--one"></span>
    <span class="oo-hero__wave oo-hero__wave--two"></span>
    <span class="oo-hero__wave oo-hero__wave--three"></span>
  </div>

  <div class="oo-hero__inner">
    <div class="oo-hero__brand">
      <img src="/brand/octave-on-logo.png" alt="Octave On" width="1064" height="671" />
    </div>

    <p class="oo-eyebrow oo-hero__eyebrow">{t.eyebrow}</p>
    <h1 class="oo-display oo-hero__title">{t.title}</h1>
    <p class="oo-hero__subtitle">{t.subtitle}</p>

    <div class="oo-hero__cta">
      <a class="oo-btn oo-btn--primary" href="#invito">{t.ctaPrimary}</a>
      <a class="oo-btn oo-btn--ghost" href="#esperienza">{t.ctaSecondary}</a>
    </div>
  </div>

  <a class="oo-hero__scroll" href="#manifesto" aria-label={t.scroll}>
    <span class="oo-hero__scroll-label">{t.scroll}</span>
    <span class="oo-hero__scroll-track" aria-hidden="true"><i></i></span>
  </a>
</header>

<style>
  .oo-hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 132px var(--oo-gutter) 104px;
    overflow: hidden;
    isolation: isolate;
    background:
      radial-gradient(ellipse at 18% 10%, rgba(20, 77, 188, 0.48) 0%, transparent 34%),
      radial-gradient(ellipse at 82% 82%, rgba(11, 61, 151, 0.42) 0%, transparent 38%),
      radial-gradient(circle at 52% 46%, rgba(9, 35, 91, 0.48) 0%, transparent 42%),
      linear-gradient(154deg, var(--oo-night-600) -24%, var(--oo-night-900) 48%, var(--oo-night-800) 100%);
  }

  .oo-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      linear-gradient(108deg, transparent 0 45%, rgba(255, 225, 154, 0.08) 50%, transparent 55%),
      radial-gradient(circle at 50% 34%, rgba(255, 255, 255, 0.045), transparent 34%);
    mix-blend-mode: screen;
  }

  .oo-hero::after {
    content: '';
    position: absolute;
    inset: auto 0 -1px;
    z-index: 1;
    height: clamp(110px, 17vh, 170px);
    pointer-events: none;
    background: linear-gradient(180deg, transparent 0%, rgba(3, 8, 36, 0.84) 72%, var(--oo-night-800) 100%);
  }

  .oo-hero__silk {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
    opacity: 0.84;
  }

  .oo-hero__silk::before,
  .oo-hero__silk::after,
  .oo-hero__wave {
    content: '';
    position: absolute;
    display: block;
    border-radius: 50%;
    pointer-events: none;
  }

  .oo-hero__silk::before {
    width: 118vw;
    height: 46vw;
    min-height: 350px;
    left: -42vw;
    top: -18vw;
    rotate: -10deg;
    border: clamp(2px, 0.22vw, 4px) solid rgba(255, 221, 142, 0.76);
    box-shadow:
      0 0 18px rgba(255, 213, 115, 0.34),
      0 0 0 clamp(18px, 2.2vw, 38px) rgba(8, 42, 111, 0.84),
      0 0 0 clamp(22px, 2.7vw, 48px) rgba(32, 103, 220, 0.32),
      0 0 80px rgba(16, 84, 207, 0.65);
    filter: blur(0.2px);
  }

  .oo-hero__silk::after {
    width: 106vw;
    height: 40vw;
    min-height: 330px;
    right: -40vw;
    bottom: -20vw;
    rotate: -13deg;
    border: clamp(2px, 0.2vw, 4px) solid rgba(255, 224, 151, 0.82);
    box-shadow:
      0 0 20px rgba(255, 217, 129, 0.4),
      0 0 0 clamp(20px, 2.4vw, 42px) rgba(7, 31, 83, 0.9),
      0 0 0 clamp(31px, 3.5vw, 64px) rgba(16, 76, 178, 0.52),
      0 0 90px rgba(13, 83, 210, 0.72);
  }

  .oo-hero__wave--one {
    width: 94vw;
    height: 22vw;
    min-height: 180px;
    left: 8vw;
    top: 27%;
    rotate: -18deg;
    border: clamp(18px, 3vw, 56px) solid rgba(8, 49, 128, 0.76);
    border-left-color: rgba(18, 91, 211, 0.82);
    filter: blur(10px);
    opacity: 0.5;
  }

  .oo-hero__wave--two {
    width: 72vw;
    height: 17vw;
    min-height: 150px;
    right: -14vw;
    top: 12%;
    rotate: -8deg;
    border: clamp(10px, 1.7vw, 30px) solid rgba(15, 79, 192, 0.34);
    filter: blur(7px);
  }

  .oo-hero__wave--three {
    width: 68vw;
    height: 24vw;
    min-height: 200px;
    left: -18vw;
    bottom: -9%;
    rotate: 9deg;
    border: clamp(12px, 2vw, 36px) solid rgba(5, 32, 91, 0.88);
    box-shadow: inset 0 0 34px rgba(21, 99, 225, 0.48);
    filter: blur(5px);
  }

  .oo-hero__inner {
    position: relative;
    z-index: 2;
    width: min(100%, 980px);
    min-width: 0;
  }

  @supports (animation-timeline: view()) {
    .oo-hero__inner > * {
      animation: revealSoft both 1s var(--oo-ease);
    }
  }

  .oo-hero__brand {
    width: clamp(300px, 34vw, 470px);
    margin: 0 auto clamp(14px, 2.4vh, 24px);
    translate: 0 -34px;
    filter:
      drop-shadow(0 0 24px rgba(245, 194, 90, 0.6))
      drop-shadow(0 16px 42px rgba(1, 3, 19, 0.8));
  }

  .oo-hero__brand img {
    width: 100%;
    height: auto;
  }

  .oo-hero__eyebrow {
    margin-bottom: 24px;
  }

  .oo-hero__title {
    width: min(100%, 900px);
    max-width: 15ch;
    margin-inline: auto;
    font-size: clamp(46px, 6.5vw, 88px);
    color: var(--oo-cream-100);
    text-wrap: balance;
    text-shadow: 0 4px 36px rgba(1, 3, 19, 0.84);
  }

  .oo-hero__subtitle {
    margin: 28px auto 0;
    max-width: 590px;
    color: rgba(241, 244, 255, 0.72);
    font-size: clamp(16px, 1.35vw, 19px);
    line-height: 1.65;
  }

  .oo-hero__cta {
    width: min(100%, 650px);
    margin: 42px auto 0;
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .oo-hero__scroll {
    position: absolute;
    bottom: 30px;
    left: 50%;
    z-index: 3;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .oo-hero__scroll-label {
    font-size: 10px;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: rgba(217, 225, 255, 0.58);
  }

  .oo-hero__scroll-track {
    position: relative;
    width: 22px;
    height: 34px;
    border: 1px solid rgba(217, 225, 255, 0.4);
    border-radius: 12px;
  }

  .oo-hero__scroll-track i {
    position: absolute;
    top: 7px;
    left: 50%;
    width: 3px;
    height: 3px;
    margin-left: -1.5px;
    border-radius: 50%;
    background: var(--oo-gold-light);
    animation: scrollDot 1.8s ease-in-out infinite;
  }

  @media (max-width: 700px) {
    .oo-hero {
      padding: 122px var(--oo-gutter) 96px;
    }

    .oo-hero__brand {
      width: min(82vw, 330px);
      margin-bottom: 18px;
      translate: 0 -26px;
    }

    .oo-hero__eyebrow {
      margin-bottom: 18px;
    }

    .oo-hero__title {
      max-width: 13ch;
      font-size: clamp(40px, 11.5vw, 54px);
    }

    .oo-hero__subtitle {
      font-size: 15px;
    }

    .oo-hero__cta {
      width: min(100%, 330px);
      flex-direction: column;
      align-items: stretch;
    }

    .oo-hero__cta .oo-btn {
      width: 100%;
    }

    .oo-hero__silk::before {
      width: 160vw;
      height: 72vw;
      left: -74vw;
      top: -12vw;
    }

    .oo-hero__silk::after {
      width: 155vw;
      height: 68vw;
      right: -78vw;
      bottom: -8vw;
    }

    .oo-hero__wave--one {
      width: 150vw;
      left: -20vw;
      top: 34%;
    }
  }

  @media (max-height: 700px) {
    .oo-hero {
      padding-top: 94px;
      padding-bottom: 62px;
    }

    .oo-hero__brand {
      width: 230px;
      margin-bottom: 4px;
      translate: 0 -20px;
    }

    .oo-hero__eyebrow {
      margin-bottom: 10px;
    }

    .oo-hero__title {
      font-size: clamp(36px, 7.2vh, 50px);
    }

    .oo-hero__subtitle {
      margin-top: 14px;
      max-width: 520px;
      font-size: 14px;
      line-height: 1.45;
    }

    .oo-hero__cta {
      margin-top: 20px;
    }

    .oo-hero__scroll {
      display: none;
    }
  }

  @media (min-width: 520px) and (max-width: 700px) and (max-height: 700px) {
    .oo-hero__cta {
      width: min(100%, 560px);
      flex-direction: row;
    }

    .oo-hero__cta .oo-btn {
      flex: 1;
      min-width: 0;
      padding-inline: 16px;
      font-size: 11.5px;
    }
  }
</style>
