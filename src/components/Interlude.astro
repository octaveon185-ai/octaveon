---
import { content, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = content[lang].interlude;
---

<section class="oo-interlude">
  <div class="oo-interlude__glow" aria-hidden="true"></div>
  <div class="oo-container oo-reveal oo-interlude__inner">
    <p class="oo-interlude__lead">{t.lead}</p>
    <h2 class="oo-display oo-interlude__text">{t.text}</h2>
  </div>
</section>

<style>
  .oo-interlude {
    position: relative;
    padding: clamp(110px, 18vh, 210px) var(--oo-gutter);
    background: var(--oo-grad-interlude);
    text-align: center;
    overflow: hidden;
  }
  .oo-interlude__glow {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 70%;
    height: 120%;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      ellipse at center,
      rgba(224, 174, 99, 0.18) 0%,
      transparent 62%
    );
    animation: glowPulse 8s ease-in-out infinite;
  }
  .oo-interlude__inner {
    position: relative;
    z-index: 1;
    max-width: 960px;
  }
  .oo-interlude__lead {
    margin: 0 0 clamp(28px, 4vh, 44px);
    color: var(--oo-gold-light);
    font-size: clamp(12px, 1.15vw, 15px);
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .oo-interlude__text {
    margin: 0;
    font-size: clamp(40px, 6.2vw, 78px);
    line-height: 1.08;
    color: var(--oo-cream-100);
    font-style: italic;
    font-weight: 400;
    text-wrap: balance;
  }

  @media (max-width: 600px) {
    .oo-interlude {
      padding-block: 110px;
    }
    .oo-interlude__lead {
      font-size: 11px;
      letter-spacing: 0.16em;
    }
    .oo-interlude__text {
      font-size: clamp(38px, 11vw, 48px);
      line-height: 1.12;
    }
  }
</style>
