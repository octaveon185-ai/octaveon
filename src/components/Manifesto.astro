---
import { content, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = content[lang].manifesto;
---

<section id="manifesto" class="oo-manifesto">
  <div class="oo-container oo-reveal">
    <article class="oo-slab">
      <div class="oo-slab__frame">
        <h2 class="oo-display oo-slab__title">{t.title}</h2>
        <p class="oo-slab__intro">{t.intro}</p>
        <span class="oo-slab__divider" aria-hidden="true"></span>
        <p class="oo-display oo-slab__vision">{t.vision}</p>
        <p class="oo-slab__body">{t.body}</p>
      </div>
    </article>
  </div>
</section>

<style>
  .oo-manifesto {
    position: relative;
    padding: clamp(80px, 13vh, 170px) var(--oo-gutter);
    display: flex;
    justify-content: center;
    background:
      radial-gradient(circle at 50% 50%, rgba(29, 93, 206, 0.2), transparent 42%),
      linear-gradient(180deg, var(--oo-night-800) 0%, var(--oo-night-700) 100%);
    overflow: hidden;
  }
  .oo-manifesto::before {
    content: none;
  }

  .oo-slab {
    position: relative;
    max-width: 960px;
    margin: 0 auto;
    border-radius: 18px;
    padding: 0;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.012)),
      rgba(2, 5, 27, 0.62);
    border: 1px solid rgba(230, 190, 102, 0.24);
    backdrop-filter: blur(18px);
    box-shadow:
      0 38px 100px rgba(1, 3, 19, 0.42),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .oo-slab__frame {
    position: relative;
    border: 0;
    outline: 0;
    border-radius: inherit;
    padding: clamp(52px, 8vw, 96px) clamp(28px, 7vw, 92px);
    text-align: center;
  }

  .oo-slab__title {
    color: var(--oo-cream-100);
    font-size: clamp(54px, 8vw, 94px);
    line-height: 0.92;
    text-shadow: 0 3px 34px rgba(1, 3, 19, 0.72);
  }

  .oo-slab__intro,
  .oo-slab__body {
    max-width: 720px;
    margin-inline: auto;
    color: rgba(234, 231, 227, 0.78);
    font-size: clamp(15px, 1.35vw, 19px);
    line-height: 1.8;
    text-wrap: pretty;
  }

  .oo-slab__intro {
    margin-top: 30px;
  }

  .oo-slab__divider {
    display: block;
    width: 72px;
    height: 1px;
    margin: clamp(34px, 5vw, 52px) auto;
    background: linear-gradient(90deg, transparent, var(--oo-gold-light), transparent);
  }

  .oo-slab__vision {
    max-width: 690px;
    margin-inline: auto;
    color: var(--oo-gold-light);
    font-size: clamp(28px, 3.7vw, 44px);
    line-height: 1.12;
    text-wrap: balance;
  }

  .oo-slab__body {
    margin-top: 30px;
  }

  @media (max-width: 600px) {
    .oo-slab__intro,
    .oo-slab__body {
      line-height: 1.7;
    }

    .oo-slab__intro {
      margin-top: 24px;
    }

    .oo-slab__body {
      margin-top: 24px;
    }
  }
</style>
