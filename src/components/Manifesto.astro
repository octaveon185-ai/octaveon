---
import { content, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = content[lang].manifesto;
---

<section id="manifesto" class="oo-manifesto">
  <div class="oo-container oo-reveal">
    <figure class="oo-slab">
      <div class="oo-slab__frame">
        <span class="oo-slab__corner oo-slab__corner--tl"></span>
        <span class="oo-slab__corner oo-slab__corner--tr"></span>
        <span class="oo-slab__corner oo-slab__corner--bl"></span>
        <span class="oo-slab__corner oo-slab__corner--br"></span>

        <p class="oo-eyebrow oo-slab__eyebrow">{t.eyebrow}</p>
        {t.lines.map((line) => (
          <p class="oo-display oo-engrave oo-slab__line">{line}</p>
        ))}
        <span class="oo-slab__divider" aria-hidden="true">
          <i></i><svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 0l1.6 6.4L16 8l-6.4 1.6L8 16l-1.6-6.4L0 8l6.4-1.6z" fill="currentColor"></path></svg><i></i>
        </span>
        <p class="oo-display oo-engrave oo-engrave--gold oo-slab__signature">{t.signature}</p>
      </div>
    </figure>
  </div>
</section>

<style>
  .oo-manifesto {
    position: relative;
    padding: clamp(80px, 13vh, 170px) var(--oo-gutter);
    display: flex;
    justify-content: center;
    background:
      radial-gradient(circle at 50% 50%, rgba(184, 115, 51, 0.13), transparent 38%),
      linear-gradient(180deg, var(--oo-night-800) 0%, var(--oo-night-700) 100%);
    overflow: hidden;
  }
  .oo-manifesto::before {
    content: '';
    position: absolute;
    inset: 4% 50% auto auto;
    width: min(68vw, 720px);
    aspect-ratio: 1;
    translate: 50% 0;
    background: url('/brand/octave-on-symbol-copper.svg') center / contain no-repeat;
    opacity: 0.055;
    filter: blur(0.2px);
  }

  /* ---- nocturnal ceremonial panel ---- */
  .oo-slab {
    position: relative;
    max-width: 880px;
    margin: 0 auto;
    border-radius: 6px;
    padding: clamp(12px, 1.6vw, 18px);
    background:
      linear-gradient(145deg, rgba(234, 231, 227, 0.055), rgba(234, 231, 227, 0.015)),
      rgba(1, 13, 22, 0.74);
    border: 1px solid rgba(211, 154, 97, 0.22);
    backdrop-filter: blur(10px);
    box-shadow:
      0 34px 90px rgba(1, 8, 13, 0.46),
      inset 0 1px 0 rgba(234, 231, 227, 0.06),
      0 0 80px rgba(184, 115, 51, 0.06);
  }

  /* double gold frame */
  .oo-slab__frame {
    position: relative;
    border: 1px solid rgba(199, 138, 58, 0.55);
    outline: 1px solid rgba(199, 138, 58, 0.28);
    outline-offset: 5px;
    border-radius: 3px;
    padding: clamp(40px, 7vw, 88px) clamp(28px, 6vw, 80px);
    text-align: center;
  }

  .oo-slab__corner {
    position: absolute;
    width: 12px;
    height: 12px;
    border: 1.5px solid var(--oo-gold);
  }
  .oo-slab__corner--tl { top: -6px; left: -6px; border-right: 0; border-bottom: 0; }
  .oo-slab__corner--tr { top: -6px; right: -6px; border-left: 0; border-bottom: 0; }
  .oo-slab__corner--bl { bottom: -6px; left: -6px; border-right: 0; border-top: 0; }
  .oo-slab__corner--br { bottom: -6px; right: -6px; border-left: 0; border-top: 0; }

  .oo-slab__eyebrow {
    color: var(--oo-gold-light);
    margin-bottom: 34px;
  }

  /* ivory text with the softness of an inscription */
  .oo-engrave {
    color: var(--oo-cream-100);
    text-shadow: 0 2px 28px rgba(1, 8, 13, 0.65);
  }
  .oo-slab__line {
    font-size: clamp(26px, 3.8vw, 50px);
    margin-bottom: 0.45em;
  }

  .oo-slab__divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    color: var(--oo-gold);
    margin: 30px 0;
  }
  .oo-slab__divider i {
    width: clamp(40px, 8vw, 96px);
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(199, 138, 58, 0.7), transparent);
  }

  .oo-engrave--gold {
    color: transparent;
    background: linear-gradient(180deg, #F0C28B 0%, #B87333 62%, #8B4E24 100%);
    -webkit-background-clip: text;
    background-clip: text;
    text-shadow: none;
    filter: drop-shadow(0 0 16px rgba(184, 115, 51, 0.22));
  }
  .oo-slab__signature {
    font-style: italic;
    font-size: clamp(22px, 2.8vw, 36px);
  }
</style>
