---
import { content, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = content[lang].manifesto;
---

<section id="manifesto" class="oo-manifesto">
  <div class="oo-container oo-reveal">
    <figure class="oo-slab">
      <div class="oo-slab__frame">
        <p class="oo-eyebrow oo-slab__eyebrow">{t.eyebrow}</p>
        {t.lines.map((line) => (
          <p class="oo-display oo-engrave oo-slab__line">{line}</p>
        ))}
        <span class="oo-slab__divider" aria-hidden="true"></span>
        <p class="oo-display oo-engrave oo-engrave--gold oo-slab__signature">{t.signature}</p>
      </div>
    </figure>
  </div>
</section>

<style>
  .oo-manifesto {
    position: relative;
    padding: clamp(80px, 13vh, 170px) var(--oo-gutter);
    display: flex;
    justify-content: center;
    background:
      radial-gradient(circle at 50% 50%, rgba(29, 93, 206, 0.2), transparent 42%),
      linear-gradient(180deg, var(--oo-night-800) 0%, var(--oo-night-700) 100%);
    overflow: hidden;
  }
  .oo-manifesto::before {
    content: none;
  }

  /* ---- nocturnal ceremonial panel ---- */
  .oo-slab {
    position: relative;
    max-width: 880px;
    margin: 0 auto;
    border-radius: 18px;
    padding: 0;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.012)),
      rgba(2, 5, 27, 0.62);
    border: 1px solid rgba(230, 190, 102, 0.24);
    backdrop-filter: blur(18px);
    box-shadow:
      0 38px 100px rgba(1, 3, 19, 0.42),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  /* double gold frame */
  .oo-slab__frame {
    position: relative;
    border: 0;
    outline: 0;
    border-radius: inherit;
    padding: clamp(40px, 7vw, 88px) clamp(28px, 6vw, 80px);
    text-align: center;
  }

  .oo-slab__eyebrow {
    color: var(--oo-gold-light);
    margin-bottom: 34px;
  }

  /* ivory text with the softness of an inscription */
  .oo-engrave {
    color: var(--oo-cream-100);
    text-shadow: 0 2px 30px rgba(1, 3, 19, 0.64);
  }
  .oo-slab__line {
    font-size: clamp(26px, 3.8vw, 50px);
    margin-bottom: 0.45em;
  }

  .oo-slab__divider {
    display: block;
    width: 72px;
    height: 1px;
    margin: 34px auto;
    background: linear-gradient(90deg, transparent, var(--oo-gold-light), transparent);
  }

  .oo-engrave--gold {
    color: transparent;
    background: linear-gradient(180deg, var(--oo-gold-glow) 0%, var(--oo-gold) 70%, var(--oo-gold-dark) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    text-shadow: none;
    filter: drop-shadow(0 0 16px rgba(184, 115, 51, 0.22));
  }
  .oo-slab__signature {
    font-size: clamp(22px, 2.8vw, 36px);
  }
</style>
