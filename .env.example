# Copy to ".dev.vars" for local Cloudflare Functions dev (wrangler pages dev),
# and set the same keys as Secrets in the Cloudflare Pages dashboard for production.

# Resend (https://resend.com) — invite & confirmation emails
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="Octave On <invito@octaveon.xyz>"
NOTIFY_TO="you@example.com"

# Cloudflare Turnstile (anti-spam on the invite form)
TURNSTILE_SECRET="0x4xxxxxxxxxxxxxxxxxxxx"
PUBLIC_TURNSTILE_SITEKEY="0x4xxxxxxxxxxxxxxxxxxxx"
